{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown && mv ../../api/index.mjs ../../api/index.js",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run api/index.js",
    "vercel-build": "tsdown && mv ../../api/index.mjs ../../api/index.js"
  },
  "dependencies": {
    "@vercel/express": "^0.1.65",
    "@vi-notes/auth": "workspace:*",
    "@vi-notes/db": "workspace:*",
    "@vi-notes/env": "workspace:*",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "nodemailer": "^6.10.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/nodemailer": "^6.4.17",
    "@vi-notes/config": "workspace:*",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
